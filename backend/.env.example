# ─────────────────────────────────────────
# REDIS (Upstash)
# How to get:
# 1. Go to upstash.com
# 2. Create free Redis database
# 3. Copy REST URL and REST Token from dashboard
# ─────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# ─────────────────────────────────────────
# AI SERVICES
# Anthropic:
# 1. Go to console.anthropic.com
# 2. Sign up - get $5 free credits, no card needed
# 3. API Keys → Create Key
# ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI (for Whisper voice - add later in Phase 6)
# 1. Go to platform.openai.com
# 2. Sign up - get $5 free credits
# 3. API Keys → Create Key
OPENAI_API_KEY=sk-your-key-here

# ─────────────────────────────────────────
# CLOUDINARY (file uploads)
# 1. Go to cloudinary.com
# 2. Sign up free - no card needed
# 3. Dashboard shows all three values
# ─────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─────────────────────────────────────────
# EMAIL (Gmail SMTP - free)
# 1. Enable 2FA on Gmail
# 2. Google Account → Security → App Passwords
# 3. Create password for Mail
# ─────────────────────────────────────────
EMAIL_FROM=your@gmail.com
EMAIL_PASS=your_gmail_app_password

# ─────────────────────────────────────────
# FRONTEND URL (for CORS)
# ─────────────────────────────────────────
FRONTEND_URL=http://localhost:5173